# 复制为 .env 后填写；docker compose 会自动读取。
# ── 接入 LLM（三选一）──
# A. Claude 官方 API Key
ANTHROPIC_API_KEY=

# B. 第三方 Anthropic 兼容端点（智谱/Kimi/DeepSeek/聚合站等）
#    填 BASE_URL + AUTH_TOKEN，留空 ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=

# ── 访问口令（公网部署强烈建议设置；浏览器用 http://host:8080/?token=xxx 访问）──
POLARIS_AUTH_TOKEN=

# ── 镜像口味 / 版本 ──
#   slim(=latest) 聊天/KB/网站生成 + 传统 PPT；full 另含 chromium+ffmpeg+CJK 字体，
#   能出 deck 截图 PPT / 视频。当前 NAS 决策：统一用 full（一个镜像全功能，不拆子镜像）。
#   想出 full：POLARIS_TAG=full（锁版本填 v1.0.5 等具体 tag）。
POLARIS_TAG=latest

# ── Docker 一键更新（容器内 Web UI 点「更新」=替身容器拉新镜像热替换）──
#   设为 1 启用。**启用前必须**同时在 docker-compose*.yml 的 volumes 段
#   取消 `- /var/run/docker.sock:/var/run/docker.sock` 这行的注释，否则按钮不出现。
#   安全提示：挂 docker.sock = 容器对宿主 docker daemon 有 root 权限，仅内网信任环境用，
#   务必同时设 POLARIS_AUTH_TOKEN。详见 DEPLOY-SYNOLOGY.md / NAS 一键更新方案。
POLARIS_DOCKER_SOCKET=0
